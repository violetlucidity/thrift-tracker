{
  "manifest_version": 2,
  "name": "Thrift Tracker",
  "version": "1.0.0",
  "description": "Save the current search page URL to your Thrift Tracker list with one click.",

  "icons": {
    "48": "icons/thrift.svg",
    "96": "icons/thrift.svg"
  },

  "browser_action": {
    "default_popup": "popup.html",
    "default_title": "Save to Thrift Tracker",
    "default_icon": {
      "48": "icons/thrift.svg"
    }
  },

  "permissions": [
    "activeTab",
    "http://127.0.0.1:5000/*"
  ]
}
